<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{{ title }} — Akshit Kobagapu</title>
<link rel="icon" href="_static/bio-photo-circle.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet" />
<style>
:root {
  --bg: #050510;
  --glass: rgba(255, 255, 255, 0.05);
  --glass-border: rgba(255, 255, 255, 0.08);
  --glass-hover: rgba(255, 255, 255, 0.09);
  --text: #f0f0f5;
  --muted: #a0a0b0;
  --dim: #5a5a6e;
  --purple: #7b2ff7;
  --cyan: #00d4ff;
  --magenta: #ff0080;
  --font-display: "Space Grotesk", -apple-system, sans-serif;
  --font-body: "Inter", -apple-system, sans-serif;
  --font-mono: "Fira Code", monospace;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--font-body);
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
  line-height: 1.6;
}

/* ── Aurora Background ── */
.aurora {
  position: fixed; inset: 0; z-index: 0;
  overflow: hidden; pointer-events: none;
}
.blob { position: absolute; border-radius: 50%; filter: blur(120px); opacity: 0.25; }
.b1 { width: 700px; height: 700px; background: var(--purple); top: -15%; left: -10%; animation: drift1 25s ease-in-out infinite; }
.b2 { width: 550px; height: 550px; background: var(--cyan); top: 40%; right: -12%; animation: drift2 30s ease-in-out infinite; }
.b3 { width: 500px; height: 500px; background: var(--magenta); bottom: -10%; left: 30%; animation: drift3 22s ease-in-out infinite; }
@keyframes drift1 { 0%,100%{transform:translate(0,0) scale(1)} 33%{transform:translate(80px,40px) scale(1.1)} 66%{transform:translate(-40px,80px) scale(.95)} }
@keyframes drift2 { 0%,100%{transform:translate(0,0) scale(1)} 33%{transform:translate(-60px,-50px) scale(1.05)} 66%{transform:translate(50px,30px) scale(.9)} }
@keyframes drift3 { 0%,100%{transform:translate(0,0) scale(1)} 33%{transform:translate(70px,-40px) scale(1.08)} 66%{transform:translate(-50px,-30px) scale(.95)} }

.grad {
  background: linear-gradient(135deg, var(--cyan), var(--purple), var(--magenta));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}

/* ── Glass Nav ── */
.top-nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: center; gap: 2.5rem;
  padding: 1rem 2rem;
  background: rgba(5,5,16,0.55); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
  border-bottom: 1px solid var(--glass-border);
}
.top-nav a { color: var(--muted); text-decoration: none; font-size: 0.85rem; font-weight: 500; letter-spacing: 0.03em; transition: color 0.3s; }
.top-nav a:hover { color: var(--text); }

/* ── Page Content ── */
.page-content { position: relative; z-index: 1; }

/* ── Reveal ── */
.reveal { opacity: 0; transform: translateY(40px); transition: opacity 0.8s ease, transform 0.8s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }

/* ── About Hero ── */
.about-hero {
  max-width: 900px; margin: 0 auto;
  padding: 10rem 2rem 4rem; text-align: center;
}
.about-hero h1 {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 6vw, 4.5rem);
  font-weight: 700; letter-spacing: -0.03em; margin-bottom: 1.5rem;
}
.about-hook {
  font-family: var(--font-mono);
  font-size: clamp(0.9rem, 1.3vw, 1.05rem);
  color: var(--muted); max-width: 42ch; margin: 0 auto;
  line-height: 1.6;
}

/* ── Bio ── */
.bio {
  max-width: 900px; margin: 0 auto; padding: 4rem 2rem;
}
.bio-grid {
  display: grid; grid-template-columns: 200px 1fr; gap: 3rem; align-items: start;
}
.bio-photo {
  width: 200px; height: 200px; border-radius: 20px;
  object-fit: cover; object-position: center 20%;
  border: 2px solid rgba(123,47,247,0.3);
  box-shadow: 0 0 50px rgba(123,47,247,0.1);
}
.bio-prose {
  background: var(--glass); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--glass-border); border-radius: 20px; padding: 2.5rem;
}
.bio-prose p { margin-bottom: 1.2rem; color: var(--muted); font-size: 0.95rem; line-height: 1.7; }
.bio-prose p:last-child { margin-bottom: 0; }
.bio-prose strong { color: var(--text); font-weight: 600; }
.bio-prose em { color: var(--cyan); font-style: normal; }

/* ── Timeline ── */
.timeline-section {
  max-width: 900px; margin: 0 auto; padding: 5rem 2rem;
}
.timeline-section h2 {
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 3.5vw, 2.5rem);
  font-weight: 700; letter-spacing: -0.02em;
  text-align: center; margin-bottom: 4rem;
}
.timeline { position: relative; padding-left: 2.5rem; }
.timeline::before {
  content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px;
  background: linear-gradient(180deg, var(--purple), var(--cyan), var(--magenta));
  border-radius: 2px;
}
.tl-entry {
  position: relative; margin-bottom: 2.5rem; padding: 1.5rem;
  background: var(--glass); backdrop-filter: blur(10px);
  border: 1px solid var(--glass-border); border-radius: 14px;
  transition: border-color 0.3s;
}
.tl-entry:hover { border-color: rgba(123,47,247,0.3); }
.tl-entry::before {
  content: ''; position: absolute; left: -2.95rem; top: 1.8rem;
  width: 10px; height: 10px; border-radius: 50%;
  background: var(--purple); border: 2px solid var(--bg);
  box-shadow: 0 0 12px rgba(123,47,247,0.4);
}
.tl-entry .year {
  font-family: var(--font-mono); font-size: 0.8rem; font-weight: 600;
  background: linear-gradient(135deg, var(--cyan), var(--purple));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  margin-bottom: 0.3rem;
}
.tl-entry .title { font-family: var(--font-display); font-weight: 600; font-size: 1.05rem; margin-bottom: 0.3rem; }
.tl-entry .title p { margin: 0; }
.tl-entry .desc { color: var(--muted); font-size: 0.88rem; line-height: 1.55; }
.tl-entry .desc p { margin: 0; }

/* Typewriter chars */
.char { opacity: 0; transition: opacity 0.04s; }
.char.shown { opacity: 1; }
.typing-caret {
  display: inline-block; width: 0.55ch; height: 1.1em;
  background: var(--cyan); vertical-align: text-bottom;
  animation: blink 1.1s steps(1) infinite;
}
@keyframes blink { 50% { opacity: 0; } }

/* ── Footer ── */
.site-footer {
  position: relative; z-index: 1; text-align: center;
  padding: 2rem; border-top: 1px solid var(--glass-border);
  font-size: 0.8rem; color: var(--dim);
}
.footer-links { margin-top: 0.5rem; }
.footer-links a { color: var(--muted); text-decoration: none; margin: 0 0.6rem; transition: color 0.2s; }
.footer-links a:hover { color: var(--cyan); }

/* ── Responsive ── */
@media (max-width: 768px) {
  .bio-grid { grid-template-columns: 1fr; justify-items: center; }
  .bio-photo { width: 150px; height: 150px; }
  .about-hero { padding: 7rem 1.25rem 3rem; }
  .bio, .timeline-section { padding: 3rem 1.25rem; }
  .top-nav { gap: 1.2rem; padding: 0.8rem 1rem; }
  .blob { opacity: 0.15; }
}
</style>
</head>
<body>

<div class="aurora" aria-hidden="true">
  <div class="blob b1"></div>
  <div class="blob b2"></div>
  <div class="blob b3"></div>
</div>

<nav class="top-nav">
  <a href="index.html">← Home</a>
  <a href="#timeline">Timeline</a>
  <a href="https://github.com/code-steadfast/" target="_blank" rel="noopener">GitHub</a>
  <a href="https://www.linkedin.com/in/akshit-kobagapu/" target="_blank" rel="noopener">LinkedIn</a>
</nav>

<div class="page-content">

<section class="about-hero reveal">
  <h1>{{ title }}<span class="grad">.</span></h1>
  <p class="about-hook">From a small town in India to building tools that power automotive teams worldwide.</p>
</section>

<section class="bio reveal">
  <div class="bio-grid">
    <img class="bio-photo" src="_static/bio-photo-circle.png" alt="" aria-hidden="true" />
    <div class="bio-prose">
      {{ body_html | safe }}
    </div>
  </div>
</section>

<section class="timeline-section reveal" id="timeline">
  <h2>Over a decade of <span class="grad">building things that matter.</span></h2>
  <div class="timeline">
    {%- for entry in timeline_entries %}
    <div class="tl-entry">
      <div class="year">{{ entry.year }}</div>
      <div class="title">{{ entry.title | md }}</div>
      <div class="desc">{{ entry.description | md }}</div>
    </div>
    {%- endfor %}
  </div>
</section>

</div>

<footer class="site-footer">
  <p>© <span id="year"></span> Akshit Kobagapu</p>
  <div class="footer-links">
    <a href="https://github.com/code-steadfast/" target="_blank" rel="noopener">GitHub</a>
    <a href="https://www.linkedin.com/in/akshit-kobagapu/" target="_blank" rel="noopener">LinkedIn</a>
  </div>
</footer>

<script>
  document.getElementById('year').textContent = new Date().getFullYear();

  // Scroll reveal
  (function () {
    const els = document.querySelectorAll('.reveal');
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } });
    }, { threshold: 0.1 });
    els.forEach(el => io.observe(el));
  })();

  // Timeline typewriter
  (function () {
    const entries = document.querySelectorAll('.tl-entry');
    if (!entries.length) return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function splitChars(root) {
      const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
      const textNodes = [];
      while (walker.nextNode()) textNodes.push(walker.currentNode);
      const chars = [];
      for (const node of textNodes) {
        const text = node.nodeValue;
        if (!text) continue;
        const frag = document.createDocumentFragment();
        for (const ch of Array.from(text)) {
          const span = document.createElement('span');
          span.className = 'char';
          span.textContent = ch;
          frag.appendChild(span);
          chars.push(span);
        }
        node.parentNode.replaceChild(frag, node);
      }
      return chars;
    }

    const data = Array.from(entries).map(el => ({
      el,
      groups: [
        { root: el.querySelector('.year'),  delay: 30, chars: [] },
        { root: el.querySelector('.title'), delay: 14, chars: [] },
        { root: el.querySelector('.desc'),  delay: 5,  chars: [] },
      ],
    }));
    for (const d of data) { for (const g of d.groups) g.chars = splitChars(g.root); }

    if (reduced) {
      for (const d of data) for (const g of d.groups) for (const c of g.chars) c.classList.add('shown');
      return;
    }

    const sleep = ms => new Promise(r => setTimeout(r, ms));
    async function typeEntry(d) {
      const caret = document.createElement('span');
      caret.className = 'typing-caret';
      for (const g of d.groups) {
        g.root.prepend(caret);
        for (const c of g.chars) { c.classList.add('shown'); c.after(caret); await sleep(g.delay); }
      }
      caret.remove();
    }

    const io = new IntersectionObserver((items) => {
      for (const e of items) {
        if (!e.isIntersecting) continue;
        const d = data.find(x => x.el === e.target);
        if (!d || d.started) continue;
        d.started = true;
        typeEntry(d);
        io.unobserve(e.target);
      }
    }, { threshold: 0.25, rootMargin: '0px 0px -10% 0px' });
    for (const d of data) io.observe(d.el);
  })();
</script>

</body>
</html>
