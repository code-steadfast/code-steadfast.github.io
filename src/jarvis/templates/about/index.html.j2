<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{{ title }} — Akshit Kobagapu</title>
<link rel="icon" href="_static/bio-photo-circle.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<style>
:root {
  --bg: #1a1c1e;
  --bg-2: #232528;
  --surface: #2a2c2f;
  --surface-2: #32353a;
  --text: #ebe9df;
  --muted: #8f9196;
  --dim: #5d6065;
  --border: #34373b;
  --accent: #4ecdc4;
  --accent-2: #ff6b6b;
  --mono: "Fira Code", ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  --sans: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; background: var(--bg); }
body {
  background: var(--bg); color: var(--text); font-family: var(--sans);
  line-height: 1.5; -webkit-font-smoothing: antialiased; overflow-x: hidden;
}
body::before {
  content: ""; position: fixed; inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.018) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.018) 1px, transparent 1px);
  background-size: 64px 64px; pointer-events: none; z-index: 0;
}

/* ── Nav ── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 1.25rem 2.5rem; display: flex; align-items: center; justify-content: space-between;
  background: rgba(26,28,30,0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}
.brand { font-family: var(--mono); font-size: 0.9rem; color: var(--accent); text-decoration: none; font-weight: 700; }
nav ul { list-style: none; display: flex; gap: 2rem; }
nav a { color: var(--muted); text-decoration: none; font-size: 0.85rem; font-weight: 500; transition: color 0.2s; }
nav a:hover { color: var(--text); }

/* ── Cards ── */
.card {
  background: var(--surface); border: 1px solid var(--border); border-radius: 16px;
  padding: 2rem; position: relative; z-index: 1;
  opacity: 0; transform: translateY(16px);
  transition: opacity 0.5s ease, transform 0.5s ease, border-color 0.3s;
}
.card.in { opacity: 1; transform: translateY(0); }
.card:hover { border-color: var(--accent); }

/* ── Layout ── */
.about-grid {
  max-width: 1100px; margin: 0 auto;
  padding: 6rem 1.5rem 2rem;
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem;
}

/* Hero card */
.card-hero {
  grid-column: span 3; padding: 3rem;
}
.card-hero .eyebrow {
  font-family: var(--mono); font-size: 0.8rem; color: var(--accent); margin-bottom: 1rem;
}
.card-hero h1 {
  font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 700;
  line-height: 0.95; letter-spacing: -0.04em; margin-bottom: 1.5rem;
}
.card-hero h1 .accent { color: var(--accent); }
.card-hero .about-hook {
  font-family: var(--mono); font-size: 0.9rem; color: var(--muted);
  border-left: 2px solid var(--accent); padding-left: 1rem; max-width: 48ch;
}

/* Photo card */
.card-photo {
  grid-column: span 1; display: flex; align-items: center; justify-content: center;
  background: var(--bg-2); padding: 1.5rem;
}
.card-photo img {
  width: 100%; max-width: 180px; aspect-ratio: 1; border-radius: 50%;
  object-fit: cover; object-position: center 20%;
  border: 3px solid var(--accent);
  box-shadow: 0 0 30px rgba(78,205,196,0.1);
}

/* Bio card */
.card-bio { grid-column: span 4; padding: 2.5rem; }
.bio-prose p { margin-bottom: 1rem; color: var(--muted); font-size: 0.95rem; line-height: 1.7; }
.bio-prose p:last-child { margin-bottom: 0; }
.bio-prose strong { color: var(--text); font-weight: 600; }
.bio-prose em { color: var(--accent); font-style: italic; }

/* Timeline header */
.card-tl-header {
  grid-column: span 4; padding: 2.5rem; text-align: center;
}
.card-tl-header .eyebrow {
  font-family: var(--mono); font-size: 0.8rem; color: var(--accent); margin-bottom: 1rem;
}
.card-tl-header h2 {
  font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 700; letter-spacing: -0.02em;
}
.card-tl-header h2 .accent { color: var(--accent); }

/* Timeline entries as cards */
.tl-grid {
  grid-column: span 4;
  display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;
}
.tl-card { padding: 1.5rem; }
.tl-card .year {
  font-family: var(--mono); font-size: 0.78rem; font-weight: 700;
  color: var(--accent); margin-bottom: 0.3rem;
}
.tl-card .title { font-weight: 600; font-size: 1rem; margin-bottom: 0.3rem; }
.tl-card .title p { margin: 0; }
.tl-card .desc { color: var(--muted); font-size: 0.85rem; line-height: 1.5; }
.tl-card .desc p { margin: 0; }

/* Typewriter */
.char { opacity: 0; transition: opacity 0.04s; }
.char.shown { opacity: 1; }
.typing-caret {
  display: inline-block; width: 0.55ch; height: 1.1em;
  background: var(--accent); vertical-align: text-bottom;
  animation: blink 1.1s steps(1) infinite;
}
@keyframes blink { 50% { opacity: 0; } }

/* Footer */
.bento-footer {
  position: relative; z-index: 1; text-align: center;
  max-width: 1100px; margin: 1rem auto 2rem; padding: 1.5rem;
  font-family: var(--mono); font-size: 0.75rem; color: var(--dim);
}
.bento-footer a { color: var(--muted); text-decoration: none; margin: 0 0.5rem; }
.bento-footer a:hover { color: var(--accent); }

@media (max-width: 768px) {
  .about-grid { grid-template-columns: 1fr; padding: 5rem 1rem 1rem; }
  .card-hero, .card-photo, .card-bio, .card-tl-header { grid-column: span 1; }
  .tl-grid { grid-column: span 1; grid-template-columns: 1fr; }
  nav { padding: 1rem 1.25rem; }
}
</style>
</head>
<body>

<nav>
  <a class="brand" href="index.html">akshitkobagapu.com</a>
  <ul>
    <li><a href="index.html">← home</a></li>
    <li><a href="#timeline">timeline</a></li>
  </ul>
</nav>

<main class="about-grid">

  <div class="card card-hero">
    <div class="eyebrow">// about</div>
    <h1>{{ title }}<span class="accent">.</span></h1>
    <p class="about-hook">From a small town in India to building tools that power automotive teams worldwide.</p>
  </div>

  <div class="card card-photo">
    <img src="_static/bio-photo-circle.png" alt="Akshit Kobagapu" />
  </div>

  <div class="card card-bio">
    <div class="bio-prose">
      {{ body_html | safe }}
    </div>
  </div>

  <div class="card card-tl-header" id="timeline">
    <div class="eyebrow">// the long version</div>
    <h2>Over a decade of <span class="accent">building things that matter.</span></h2>
  </div>

  <div class="tl-grid">
    {%- for entry in timeline_entries %}
    <div class="card tl-card">
      <div class="year">{{ entry.year }}</div>
      <div class="title">{{ entry.title | md }}</div>
      <div class="desc">{{ entry.description | md }}</div>
    </div>
    {%- endfor %}
  </div>

</main>

<footer class="bento-footer">
  <div>© <span id="year"></span> Akshit Kobagapu ·
    <a href="https://github.com/code-steadfast/" target="_blank" rel="noopener">github</a>
    <a href="https://www.linkedin.com/in/akshit-kobagapu/" target="_blank" rel="noopener">linkedin</a>
  </div>
</footer>

<script>
  document.getElementById('year').textContent = new Date().getFullYear();

  // Card reveal
  (function () {
    const cards = document.querySelectorAll('.card');
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
    }, { threshold: 0.1 });
    cards.forEach((c, i) => { c.style.transitionDelay = (i * 80) + 'ms'; io.observe(c); });
  })();

  // Timeline typewriter
  (function () {
    const entries = document.querySelectorAll('.tl-card');
    if (!entries.length) return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function splitChars(root) {
      const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
      const textNodes = [];
      while (walker.nextNode()) textNodes.push(walker.currentNode);
      const chars = [];
      for (const node of textNodes) {
        const text = node.nodeValue; if (!text) continue;
        const frag = document.createDocumentFragment();
        for (const ch of Array.from(text)) {
          const span = document.createElement('span');
          span.className = 'char'; span.textContent = ch;
          frag.appendChild(span); chars.push(span);
        }
        node.parentNode.replaceChild(frag, node);
      }
      return chars;
    }

    const data = Array.from(entries).map(el => ({
      el, groups: [
        { root: el.querySelector('.year'),  delay: 30, chars: [] },
        { root: el.querySelector('.title'), delay: 14, chars: [] },
        { root: el.querySelector('.desc'),  delay: 5,  chars: [] },
      ],
    }));
    for (const d of data) for (const g of d.groups) g.chars = splitChars(g.root);

    if (reduced) { for (const d of data) for (const g of d.groups) for (const c of g.chars) c.classList.add('shown'); return; }

    const sleep = ms => new Promise(r => setTimeout(r, ms));
    async function typeEntry(d) {
      const caret = document.createElement('span'); caret.className = 'typing-caret';
      for (const g of d.groups) { g.root.prepend(caret); for (const c of g.chars) { c.classList.add('shown'); c.after(caret); await sleep(g.delay); } }
      caret.remove();
    }

    const io = new IntersectionObserver((items) => {
      for (const e of items) {
        if (!e.isIntersecting) continue;
        const d = data.find(x => x.el === e.target);
        if (!d || d.started) continue;
        d.started = true; typeEntry(d); io.unobserve(e.target);
      }
    }, { threshold: 0.25, rootMargin: '0px 0px -10% 0px' });
    for (const d of data) io.observe(d.el);
  })();
</script>

</body>
</html>
