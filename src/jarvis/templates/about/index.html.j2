<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{{ title }} — Akshit Kobagapu</title>
<link rel="icon" href="_static/bio-photo-circle.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet" />
<style>
:root {
  --bg: #0f0f1a;
  --surface: #1a1a2e;
  --text: #f5f0e8;
  --muted: #9a9590;
  --dim: #5a5565;
  --border: #2e2e45;
  --orange: #ff6a00;
  --gold: #ffd700;
  --crimson: #e63946;
  --font-display: "Bebas Neue", Impact, sans-serif;
  --font-body: "Inter", -apple-system, sans-serif;
  --font-mono: "Fira Code", monospace;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg); color: var(--text); font-family: var(--font-body);
  -webkit-font-smoothing: antialiased; overflow-x: hidden; line-height: 1.6;
}

/* Speed lines */
.speed-lines {
  position: fixed; inset: 0; z-index: 0; pointer-events: none; opacity: 0.04;
  background: repeating-conic-gradient(var(--text) 0deg 0.5deg, transparent 0.5deg 3deg) center / 100% 100%;
}

/* Nav */
.top-nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 1rem 2.5rem;
  background: rgba(15,15,26,0.85); backdrop-filter: blur(12px);
  border-bottom: 2px solid var(--orange);
}
.top-nav .brand {
  font-family: var(--font-display); font-size: 1.4rem;
  color: var(--orange); text-decoration: none; letter-spacing: 0.08em;
}
.nav-links { display: flex; gap: 2rem; }
.nav-links a {
  color: var(--muted); text-decoration: none; font-size: 0.85rem;
  font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--orange); }

/* Arc label */
.arc-label {
  font-family: var(--font-display); font-size: 0.9rem;
  color: var(--orange); letter-spacing: 0.25em; text-transform: uppercase;
  margin-bottom: 0.8rem; display: flex; align-items: center; gap: 0.8rem;
}
.arc-label::after { content: ''; flex: 1; height: 2px; background: var(--orange); opacity: 0.3; }

/* Reveal */
.reveal {
  opacity: 0; transform: translateY(40px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.visible { opacity: 1; transform: translateY(0); }

/* Page */
.page { position: relative; z-index: 1; }
.section { max-width: 900px; margin: 0 auto; padding: 6rem 2rem; }
.section h2 {
  font-family: var(--font-display);
  font-size: clamp(2rem, 4vw, 3rem);
  letter-spacing: 0.04em; margin-bottom: 2rem;
}
.section h2 .accent { color: var(--orange); }
.section h2 .gold { color: var(--gold); }

/* Hero */
.about-hero {
  padding: 10rem 2rem 4rem; text-align: center;
  max-width: 900px; margin: 0 auto;
}
.about-hero h1 {
  font-family: var(--font-display);
  font-size: clamp(3rem, 8vw, 5rem);
  letter-spacing: 0.06em; margin-bottom: 1.5rem;
}
.about-hero h1 .accent { color: var(--orange); }
.about-hook {
  font-size: 1.05rem; color: var(--muted);
  max-width: 42ch; margin: 0 auto; line-height: 1.6;
}

/* Bio */
.bio-grid {
  display: grid; grid-template-columns: 200px 1fr; gap: 2.5rem; align-items: start;
}
.bio-photo {
  width: 200px; height: 200px; border-radius: 4px;
  object-fit: cover; object-position: center 20%;
  border: 3px solid var(--orange);
  box-shadow: 0 0 40px rgba(255,106,0,0.1);
}
.bio-prose {
  background: var(--surface); border: 2px solid var(--border);
  border-radius: 4px; padding: 2.5rem; position: relative;
}
.bio-prose::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0;
  height: 3px; background: var(--orange);
}
.bio-prose p { margin-bottom: 1rem; color: var(--muted); font-size: 0.95rem; line-height: 1.7; }
.bio-prose p:last-child { margin-bottom: 0; }
.bio-prose strong { color: var(--text); font-weight: 600; }
.bio-prose em { color: var(--orange); font-style: italic; }

/* Timeline */
.timeline { position: relative; padding-left: 2.5rem; }
.timeline::before {
  content: ''; position: absolute; left: 0; top: 0; bottom: 0;
  width: 3px; background: linear-gradient(180deg, var(--orange), var(--gold), var(--crimson));
  border-radius: 3px;
}
.tl-entry {
  position: relative; margin-bottom: 2rem; padding: 1.5rem;
  background: var(--surface); border: 2px solid var(--border);
  border-radius: 4px; transition: border-color 0.3s;
}
.tl-entry:hover { border-color: var(--orange); }
.tl-entry::before {
  content: ''; position: absolute; left: -2.95rem; top: 1.8rem;
  width: 12px; height: 12px; border-radius: 50%;
  background: var(--orange); border: 3px solid var(--bg);
  box-shadow: 0 0 10px rgba(255,106,0,0.4);
}
.tl-entry .year {
  font-family: var(--font-display); font-size: 1rem;
  color: var(--gold); letter-spacing: 0.1em; margin-bottom: 0.2rem;
}
.tl-entry .title {
  font-family: var(--font-display); font-size: 1.1rem;
  letter-spacing: 0.04em; margin-bottom: 0.3rem;
}
.tl-entry .title p { margin: 0; }
.tl-entry .desc { color: var(--muted); font-size: 0.88rem; line-height: 1.55; }
.tl-entry .desc p { margin: 0; }

/* Typewriter */
.char { opacity: 0; transition: opacity 0.04s; }
.char.shown { opacity: 1; }
.typing-caret {
  display: inline-block; width: 0.55ch; height: 1.1em;
  background: var(--orange); vertical-align: text-bottom;
  animation: blink 1.1s steps(1) infinite;
}
@keyframes blink { 50% { opacity: 0; } }

/* Footer */
.site-footer {
  position: relative; z-index: 1; text-align: center;
  padding: 2rem; border-top: 2px solid var(--orange);
  font-size: 0.8rem; color: var(--dim);
}
.footer-links { margin-top: 0.5rem; }
.footer-links a {
  color: var(--muted); text-decoration: none; margin: 0 0.8rem;
  font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase;
  font-size: 0.75rem; transition: color 0.2s;
}
.footer-links a:hover { color: var(--orange); }

@media (max-width: 768px) {
  .bio-grid { grid-template-columns: 1fr; justify-items: center; }
  .bio-photo { width: 150px; height: 150px; }
  .about-hero { padding: 7rem 1.25rem 3rem; }
  .section { padding: 4rem 1.25rem; }
  .top-nav { padding: 0.8rem 1.25rem; }
  .nav-links { display: none; }
  .speed-lines { opacity: 0.02; }
}
</style>
</head>
<body>

<div class="speed-lines" aria-hidden="true"></div>

<nav class="top-nav">
  <a class="brand" href="index.html">AKSHIT K.</a>
  <div class="nav-links">
    <a href="index.html">← Home</a>
    <a href="#timeline">Timeline</a>
    <a href="https://github.com/code-steadfast/" target="_blank" rel="noopener">GitHub</a>
    <a href="https://www.linkedin.com/in/akshit-kobagapu/" target="_blank" rel="noopener">LinkedIn</a>
  </div>
</nav>

<div class="page">

<section class="about-hero reveal">
  <h1>{{ title }}<span class="accent">.</span></h1>
  <p class="about-hook">From a small town in India to building tools that power automotive teams worldwide.</p>
</section>

<section class="section reveal">
  <div class="arc-label">THE ORIGIN</div>
  <div class="bio-grid">
    <img class="bio-photo" src="_static/bio-photo-circle.png" alt="Akshit Kobagapu" />
    <div class="bio-prose">
      {{ body_html | safe }}
    </div>
  </div>
</section>

<section class="section reveal" id="timeline">
  <div class="arc-label">THE JOURNEY</div>
  <h2>OVER A DECADE OF <span class="gold">BUILDING THINGS THAT MATTER.</span></h2>
  <div class="timeline">
    {%- for entry in timeline_entries %}
    <div class="tl-entry">
      <div class="year">{{ entry.year }}</div>
      <div class="title">{{ entry.title | md }}</div>
      <div class="desc">{{ entry.description | md }}</div>
    </div>
    {%- endfor %}
  </div>
</section>

</div>

<footer class="site-footer">
  <p>© <span id="year"></span> Akshit Kobagapu · Built with curiosity and Python</p>
  <div class="footer-links">
    <a href="https://github.com/code-steadfast/" target="_blank" rel="noopener">GitHub</a>
    <a href="https://www.linkedin.com/in/akshit-kobagapu/" target="_blank" rel="noopener">LinkedIn</a>
  </div>
</footer>

<script>
  document.getElementById('year').textContent = new Date().getFullYear();

  // Reveal
  (function () {
    const els = document.querySelectorAll('.reveal');
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } });
    }, { threshold: 0.1 });
    els.forEach(el => io.observe(el));
  })();

  // Typewriter
  (function () {
    const entries = document.querySelectorAll('.tl-entry');
    if (!entries.length) return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function splitChars(root) {
      const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
      const textNodes = [];
      while (walker.nextNode()) textNodes.push(walker.currentNode);
      const chars = [];
      for (const node of textNodes) {
        const text = node.nodeValue; if (!text) continue;
        const frag = document.createDocumentFragment();
        for (const ch of Array.from(text)) {
          const span = document.createElement('span');
          span.className = 'char'; span.textContent = ch;
          frag.appendChild(span); chars.push(span);
        }
        node.parentNode.replaceChild(frag, node);
      }
      return chars;
    }

    const data = Array.from(entries).map(el => ({
      el, groups: [
        { root: el.querySelector('.year'),  delay: 30, chars: [] },
        { root: el.querySelector('.title'), delay: 14, chars: [] },
        { root: el.querySelector('.desc'),  delay: 5,  chars: [] },
      ],
    }));
    for (const d of data) for (const g of d.groups) g.chars = splitChars(g.root);

    if (reduced) { for (const d of data) for (const g of d.groups) for (const c of g.chars) c.classList.add('shown'); return; }

    const sleep = ms => new Promise(r => setTimeout(r, ms));
    async function typeEntry(d) {
      const caret = document.createElement('span'); caret.className = 'typing-caret';
      for (const g of d.groups) { g.root.prepend(caret); for (const c of g.chars) { c.classList.add('shown'); c.after(caret); await sleep(g.delay); } }
      caret.remove();
    }

    const io = new IntersectionObserver((items) => {
      for (const e of items) {
        if (!e.isIntersecting) continue;
        const d = data.find(x => x.el === e.target);
        if (!d || d.started) continue;
        d.started = true; typeEntry(d); io.unobserve(e.target);
      }
    }, { threshold: 0.25, rootMargin: '0px 0px -10% 0px' });
    for (const d of data) io.observe(d.el);
  })();
</script>

</body>
</html>
