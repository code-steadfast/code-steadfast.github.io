<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{{ title }} — Akshit Kobagapu</title>
<link rel="icon" href="_static/bio-photo-circle.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<style>
:root {
  --bg: #1a1c1e;
  --bg-2: #232528;
  --surface: #2a2c2f;
  --surface-2: #32353a;
  --text: #ebe9df;
  --muted: #8f9196;
  --dim: #5d6065;
  --border: #34373b;
  --accent: #4ecdc4;
  --accent-2: #ff6b6b;
  --mono: "Fira Code", ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  --sans: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; background: var(--bg); }
body {
  background: var(--bg); color: var(--text); font-family: var(--sans);
  line-height: 1.5; -webkit-font-smoothing: antialiased; overflow-x: hidden;
}

/* ── Split Layout ── */
.split { display: flex; min-height: 100vh; }

/* Left Panel — fixed sidebar */
.panel-left {
  position: fixed; top: 0; left: 0; bottom: 0; width: 340px;
  background: var(--bg-2); border-right: 1px solid var(--border);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 2.5rem; text-align: center; z-index: 10;
}
.panel-photo {
  width: 120px; height: 120px; border-radius: 50%;
  object-fit: cover; object-position: center 20%;
  border: 3px solid var(--accent);
  box-shadow: 0 0 30px rgba(78,205,196,0.1);
  margin-bottom: 1.5rem;
}
.panel-left h1 {
  font-size: 1.8rem; font-weight: 700; line-height: 1;
  letter-spacing: -0.03em; margin-bottom: 0.8rem;
}
.panel-left h1 .accent { color: var(--accent); }
.panel-role {
  font-family: var(--mono); font-size: 0.75rem; color: var(--accent);
  margin-bottom: 0.8rem;
}
.panel-tagline {
  font-size: 0.85rem; color: var(--muted); margin-bottom: 1.5rem; line-height: 1.5;
}
.panel-nav { list-style: none; display: flex; flex-direction: column; gap: 0.8rem; margin-bottom: 2rem; width: 100%; }
.panel-nav a {
  display: block; padding: 0.6rem 1rem; border-radius: 8px;
  font-family: var(--mono); font-size: 0.8rem; color: var(--muted);
  text-decoration: none; border: 1px solid var(--border); transition: all 0.2s;
}
.panel-nav a:hover { color: var(--text); border-color: var(--accent); background: rgba(78,205,196,0.05); }
.panel-social { display: flex; gap: 1rem; margin-top: 1rem; }
.panel-social a {
  color: var(--muted); text-decoration: none; font-family: var(--mono);
  font-size: 0.85rem; font-weight: 700; transition: color 0.2s;
}
.panel-social a:hover { color: var(--accent); }

/* Right Panel — scrollable content */
.panel-right {
  margin-left: 340px; flex: 1; padding: 3rem 3rem 2rem;
  min-height: 100vh;
}

/* Cards */
.split-card {
  background: var(--surface); border: 1px solid var(--border); border-radius: 16px;
  padding: 2rem; margin-bottom: 1.5rem;
  opacity: 0; transform: translateY(16px);
  transition: opacity 0.5s ease, transform 0.5s ease, border-color 0.3s;
}
.split-card.in { opacity: 1; transform: translateY(0); }
.split-card:hover { border-color: var(--accent); }
.split-heading {
  font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1.5rem;
}
.split-heading .accent { color: var(--accent); }

/* Bio prose */
.bio-prose p { margin-bottom: 1rem; color: var(--muted); font-size: 0.95rem; line-height: 1.7; }
.bio-prose p:last-child { margin-bottom: 0; }
.bio-prose strong { color: var(--text); font-weight: 600; }
.bio-prose em { color: var(--accent); font-style: italic; }

/* Timeline */
.tl-entry {
  padding: 1.2rem 0; border-bottom: 1px solid var(--border);
}
.tl-entry:last-child { border-bottom: none; }
.tl-entry .year {
  font-family: var(--mono); font-size: 0.78rem; font-weight: 700;
  color: var(--accent); margin-bottom: 0.3rem;
}
.tl-entry .title { font-weight: 600; font-size: 1rem; margin-bottom: 0.3rem; }
.tl-entry .title p { margin: 0; }
.tl-entry .desc { color: var(--muted); font-size: 0.85rem; line-height: 1.5; }
.tl-entry .desc p { margin: 0; }

/* Typewriter */
.char { opacity: 0; transition: opacity 0.04s; }
.char.shown { opacity: 1; }
.typing-caret {
  display: inline-block; width: 0.55ch; height: 1.1em;
  background: var(--accent); vertical-align: text-bottom;
  animation: blink 1.1s steps(1) infinite;
}
@keyframes blink { 50% { opacity: 0; } }

/* Footer */
.split-footer {
  text-align: center; padding: 2rem 0;
  font-family: var(--mono); font-size: 0.75rem; color: var(--dim);
}

@media (max-width: 768px) {
  .split { flex-direction: column; }
  .panel-left {
    position: relative; width: 100%; padding: 2rem 1.5rem;
    border-right: none; border-bottom: 1px solid var(--border);
  }
  .panel-right { margin-left: 0; padding: 1.5rem; }
}
</style>
</head>
<body>

<div class="split">

  <aside class="panel-left">
    <img src="_static/bio-photo-circle.png" alt="Akshit Kobagapu" class="panel-photo" />
    <h1>Akshit<br/><span class="accent">Kobagapu</span><span class="accent">.</span></h1>
    <p class="panel-role">// about me</p>
    <p class="panel-tagline">From a small town in India to building tools that power automotive teams worldwide.</p>
    <nav>
      <ul class="panel-nav">
        <li><a href="index.html">← Home</a></li>
        <li><a href="#bio">Bio</a></li>
        <li><a href="#timeline">Timeline</a></li>
      </ul>
    </nav>
    <div class="panel-social">
      <a href="https://github.com/code-steadfast/" target="_blank" rel="noopener" title="GitHub">⟨/⟩</a>
      <a href="https://www.linkedin.com/in/akshit-kobagapu/" target="_blank" rel="noopener" title="LinkedIn">in</a>
    </div>
  </aside>

  <main class="panel-right">

    <section class="split-card" id="bio">
      <h2 class="split-heading">{{ title }}<span class="accent">.</span></h2>
      <div class="bio-prose">
        {{ body_html | safe }}
      </div>
    </section>

    <section class="split-card" id="timeline">
      <h2 class="split-heading">Over a decade of building things that matter<span class="accent">.</span></h2>
      {%- for entry in timeline_entries %}
      <div class="tl-entry">
        <div class="year">{{ entry.year }}</div>
        <div class="title">{{ entry.title | md }}</div>
        <div class="desc">{{ entry.description | md }}</div>
      </div>
      {%- endfor %}
    </section>

    <footer class="split-footer">
      © <span id="year"></span> Akshit Kobagapu · Built with curiosity and Python
    </footer>

  </main>

</div>

<script>
  document.getElementById('year').textContent = new Date().getFullYear();

  // Card reveal
  (function () {
    const cards = document.querySelectorAll('.split-card');
    const io = new IntersectionObserver((items) => {
      items.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
    }, { threshold: 0.1 });
    cards.forEach((c, i) => { c.style.transitionDelay = (i * 100) + 'ms'; io.observe(c); });
  })();

  // Timeline typewriter
  (function () {
    const entries = document.querySelectorAll('.tl-entry');
    if (!entries.length) return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function splitChars(root) {
      const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
      const textNodes = [];
      while (walker.nextNode()) textNodes.push(walker.currentNode);
      const chars = [];
      for (const node of textNodes) {
        const text = node.nodeValue; if (!text) continue;
        const frag = document.createDocumentFragment();
        for (const ch of Array.from(text)) {
          const span = document.createElement('span');
          span.className = 'char'; span.textContent = ch;
          frag.appendChild(span); chars.push(span);
        }
        node.parentNode.replaceChild(frag, node);
      }
      return chars;
    }

    const data = Array.from(entries).map(el => ({
      el, groups: [
        { root: el.querySelector('.year'),  delay: 30, chars: [] },
        { root: el.querySelector('.title'), delay: 14, chars: [] },
        { root: el.querySelector('.desc'),  delay: 5,  chars: [] },
      ],
    }));
    for (const d of data) for (const g of d.groups) g.chars = splitChars(g.root);

    if (reduced) { for (const d of data) for (const g of d.groups) for (const c of g.chars) c.classList.add('shown'); return; }

    const sleep = ms => new Promise(r => setTimeout(r, ms));
    async function typeEntry(d) {
      const caret = document.createElement('span'); caret.className = 'typing-caret';
      for (const g of d.groups) { g.root.prepend(caret); for (const c of g.chars) { c.classList.add('shown'); c.after(caret); await sleep(g.delay); } }
      caret.remove();
    }

    const io = new IntersectionObserver((items) => {
      for (const e of items) {
        if (!e.isIntersecting) continue;
        const d = data.find(x => x.el === e.target);
        if (!d || d.started) continue;
        d.started = true; typeEntry(d); io.unobserve(e.target);
      }
    }, { threshold: 0.25, rootMargin: '0px 0px -10% 0px' });
    for (const d of data) io.observe(d.el);
  })();
</script>

</body>
</html>
