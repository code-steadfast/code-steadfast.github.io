<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{{ title }} — Akshit Kobagapu</title>
<link rel="icon" href="_static/bio-photo-circle.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&display=swap" rel="stylesheet" />
<style>
:root {
  --bg: #0c0c0c;
  --text: #c8c8c8;
  --accent: #4ecdc4;
  --prompt: #4ecdc4;
  --cmd: #ffffff;
  --dim: #555;
  --link: #ff6b6b;
  --mono: "Fira Code", ui-monospace, "SF Mono", Menlo, Consolas, monospace;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body { background: var(--bg); color: var(--text); font-family: var(--mono); font-size: 15px; line-height: 1.7; }

.terminal {
  max-width: 860px; margin: 0 auto;
  padding: 1.5rem 2rem 4rem; min-height: 100vh;
}

/* Window chrome */
.window-bar {
  display: flex; align-items: center; gap: 0.5rem;
  padding: 1rem 0 2rem; position: sticky; top: 0;
  background: var(--bg); z-index: 10;
}
.window-bar .dot { width: 12px; height: 12px; border-radius: 50%; }
.window-bar .dot:nth-child(1) { background: #ff5f56; }
.window-bar .dot:nth-child(2) { background: #ffbd2e; }
.window-bar .dot:nth-child(3) { background: #27c93f; }
.window-bar .title { margin-left: 1rem; color: var(--dim); font-size: 0.8rem; }

/* Command blocks */
.cmd-block { margin-bottom: 2rem; opacity: 0; transform: translateY(8px); transition: opacity 0.4s ease, transform 0.4s ease; }
.cmd-block.visible { opacity: 1; transform: translateY(0); }
.prompt { color: var(--prompt); }
.command { color: var(--cmd); font-weight: 700; }
.output { margin-top: 0.3rem; }
.output p { margin: 0.3rem 0; color: var(--text); }
.output .highlight { color: var(--accent); }
.output .dim { color: var(--dim); }
.output a { color: var(--accent); text-decoration: none; }
.output a:hover { text-decoration: underline; }

/* Bio rendered as terminal output */
.bio-output p { margin: 0.6rem 0; color: var(--text); font-size: 0.9rem; line-height: 1.7; }
.bio-output strong { color: var(--cmd); font-weight: 700; }
.bio-output em { color: var(--accent); font-style: normal; }

/* Timeline as log entries */
.tl-entry { margin-bottom: 1.2rem; padding-left: 1rem; border-left: 2px solid #222; }
.tl-entry .year { color: var(--accent); font-weight: 700; font-size: 0.85rem; }
.tl-entry .title { color: var(--cmd); font-weight: 600; }
.tl-entry .title p { margin: 0; }
.tl-entry .desc { color: var(--dim); font-size: 0.85rem; }
.tl-entry .desc p { margin: 0; }

/* Typewriter */
.char { opacity: 0; transition: opacity 0.04s; }
.char.shown { opacity: 1; }
.typing-caret {
  display: inline-block; width: 0.6ch; height: 1.15em;
  background: var(--accent); vertical-align: text-bottom;
  animation: blink 1.1s steps(1) infinite;
}
@keyframes blink { 50% { opacity: 0; } }

/* Cursor */
.cursor-line .cursor {
  display: inline-block; width: 0.6ch; height: 1.15em;
  background: var(--accent); vertical-align: text-bottom;
  animation: blink 1.1s steps(1) infinite;
}

/* Footer */
.term-footer {
  margin-top: 3rem; padding-top: 1rem;
  border-top: 1px solid #222; color: var(--dim); font-size: 0.75rem;
}
.term-footer a { color: var(--dim); text-decoration: none; }
.term-footer a:hover { color: var(--accent); }

@media (max-width: 600px) {
  .terminal { padding: 1rem 1rem 3rem; font-size: 13px; }
}
</style>
</head>
<body>

<div class="terminal">

  <div class="window-bar">
    <div class="dot"></div><div class="dot"></div><div class="dot"></div>
    <span class="title">akshit@kobagapu: ~/about</span>
  </div>

  <!-- Navigation -->
  <div class="cmd-block">
    <div><span class="prompt">akshit@kobagapu:~$</span> <span class="command">cd ../</span></div>
    <div class="output">
      <p><a href="index.html">← back to home</a></p>
    </div>
  </div>

  <!-- About header -->
  <div class="cmd-block">
    <div><span class="prompt">akshit@kobagapu:~$</span> <span class="command">cat about.md</span></div>
    <div class="output">
      <p><span class="highlight">## {{ title }}</span></p>
      <p class="dim">From a small town in India to building tools that power automotive teams worldwide.</p>
    </div>
  </div>

  <!-- Bio -->
  <div class="cmd-block">
    <div><span class="prompt">akshit@kobagapu:~$</span> <span class="command">cat bio.txt</span></div>
    <div class="output bio-output">
      {{ body_html | safe }}
    </div>
  </div>

  <!-- Timeline -->
  <div class="cmd-block">
    <div><span class="prompt">akshit@kobagapu:~$</span> <span class="command">git log --oneline --reverse career.log</span></div>
    <div class="output">
      <p class="dim"># Showing {{ timeline_entries | length }} entries...</p>
    </div>
  </div>

  {%- for entry in timeline_entries %}
  <div class="cmd-block">
    <div class="tl-entry">
      <div class="year">{{ entry.year }}</div>
      <div class="title">{{ entry.title | md }}</div>
      <div class="desc">{{ entry.description | md }}</div>
    </div>
  </div>
  {%- endfor %}

  <!-- Links -->
  <div class="cmd-block">
    <div><span class="prompt">akshit@kobagapu:~$</span> <span class="command">cat links.txt</span></div>
    <div class="output">
      <p><a href="https://github.com/code-steadfast/" target="_blank" rel="noopener">github.com/code-steadfast</a></p>
      <p><a href="https://www.linkedin.com/in/akshit-kobagapu/" target="_blank" rel="noopener">linkedin.com/in/akshit-kobagapu</a></p>
    </div>
  </div>

  <!-- Waiting cursor -->
  <div class="cmd-block cursor-line">
    <span class="prompt">akshit@kobagapu:~$</span> <span class="cursor"></span>
  </div>

  <footer class="term-footer">
    © <span id="year"></span> Akshit Kobagapu ·
    <a href="https://github.com/code-steadfast/" target="_blank" rel="noopener">github</a> ·
    <a href="https://www.linkedin.com/in/akshit-kobagapu/" target="_blank" rel="noopener">linkedin</a>
  </footer>

</div>

<script>
  document.getElementById('year').textContent = new Date().getFullYear();

  // Sequential reveal of command blocks
  (function () {
    const blocks = document.querySelectorAll('.cmd-block');
    let delay = 0;
    blocks.forEach(b => {
      setTimeout(() => b.classList.add('visible'), delay);
      delay += 250;
    });
  })();

  // Timeline typewriter
  (function () {
    const entries = document.querySelectorAll('.tl-entry');
    if (!entries.length) return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function splitChars(root) {
      const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
      const textNodes = [];
      while (walker.nextNode()) textNodes.push(walker.currentNode);
      const chars = [];
      for (const node of textNodes) {
        const text = node.nodeValue; if (!text) continue;
        const frag = document.createDocumentFragment();
        for (const ch of Array.from(text)) {
          const span = document.createElement('span');
          span.className = 'char'; span.textContent = ch;
          frag.appendChild(span); chars.push(span);
        }
        node.parentNode.replaceChild(frag, node);
      }
      return chars;
    }

    const data = Array.from(entries).map(el => ({
      el, groups: [
        { root: el.querySelector('.year'),  delay: 30, chars: [] },
        { root: el.querySelector('.title'), delay: 14, chars: [] },
        { root: el.querySelector('.desc'),  delay: 5,  chars: [] },
      ],
    }));
    for (const d of data) for (const g of d.groups) g.chars = splitChars(g.root);

    if (reduced) { for (const d of data) for (const g of d.groups) for (const c of g.chars) c.classList.add('shown'); return; }

    const sleep = ms => new Promise(r => setTimeout(r, ms));
    async function typeEntry(d) {
      const caret = document.createElement('span'); caret.className = 'typing-caret';
      for (const g of d.groups) { g.root.prepend(caret); for (const c of g.chars) { c.classList.add('shown'); c.after(caret); await sleep(g.delay); } }
      caret.remove();
    }

    const io = new IntersectionObserver((items) => {
      for (const e of items) {
        if (!e.isIntersecting) continue;
        const d = data.find(x => x.el === e.target);
        if (!d || d.started) continue;
        d.started = true; typeEntry(d); io.unobserve(e.target);
      }
    }, { threshold: 0.25, rootMargin: '0px 0px -10% 0px' });
    for (const d of data) io.observe(d.el);
  })();
</script>

</body>
</html>
